# ─────────────────────────────────────────────────────────────────────────────
# AfroEval Scorecard™ — Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
AFROEVAL_ENV=development          # development | staging | production
AFROEVAL_SECRET_KEY=change-me-to-a-random-64-char-string
AFROEVAL_LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────────────────────
# Local development: spin up with  docker compose up -d db
DATABASE_URL=postgresql://afroeval:afroeval@localhost:5432/afroeval_dev

# ── Model connectors ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o

AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini

GEMINI_API_KEY=...

# ── Evaluation ───────────────────────────────────────────────────────────────
# Model used as the LLM-judge inside the Africa Intelligence Layer
AIL_JUDGE_MODEL=gpt-4.1-mini
AIL_JUDGE_PROVIDER=azure_openai    # openai | azure_openai

# ── Reporting ────────────────────────────────────────────────────────────────
SCORECARD_OUTPUT_DIR=./output/scorecards

# ── HITL / Label Studio ──────────────────────────────────────────────────────
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=...

# ── Azure (production / staging only) ────────────────────────────────────────
# AZURE_STORAGE_CONNECTION_STRING=...
# AZURE_BLOB_CONTAINER=afroeval-artifacts
